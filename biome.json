{
    "$schema": "https://biomejs.dev/schemas/2.1.3/schema.json",
    "files": {
        "ignoreUnknown": true
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noForEach": "off",
                "noUselessFragments": "off"
            },
            "correctness": {
                "useExhaustiveDependencies": "off",
                "noUnusedImports": "warn",
                "noUnusedVariables": "warn"
            },
            "style": {
                "noParameterAssign": "off",
                "useImportType": "off"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": false,
        "indentStyle": "tab",
        "lineEnding": "lf",
        "lineWidth": 100
    }
}