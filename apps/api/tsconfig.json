{
	"extends": "@skillers/tsconfig/nest.json",
	"compilerOptions": {
		"baseUrl": "./",
		"outDir": "./dist",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"noEmit": false,
		"incremental": false
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "generated"]
}
